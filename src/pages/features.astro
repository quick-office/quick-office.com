---
import DynamicIcon from '@/components/helpers/DynamicIcon';
import { SiteLayout } from '@/layouts/site-layout';
import { BrandsCarousel, CallToAction, Faq, GradientBlob, ImageMod } from '@/components';
import { Button } from '@/components/ui/button';
import { Section } from '@/components/ui/section';
import { BusinessNeeds, ComparisonRow, ShowcaseCard } from '@/screens/features';
import { markdownify } from '@/lib/text-converter';
import { Container } from '@/components/ui/container';
import {
    quickOfficeDashboard,
    featureAutomatedMarketing,
    featureAiPoweredGraph,
    featureGrowYourEarnings,
    featureTurnoverTable,
    featureMarketingAutopilot,
    featureServiceFeature1,
    featureServiceFeature2,
} from '@/lib/assets';

const featuresData = {
    banner: {
        title: 'Features That Turn <br /> Attention <strong>Into Revenue</strong>',
        content:
            'A single piece of software built to manage your entire business on autopilot. Say goodbye to scattered tools and forgotten leads.',
        button_primary: { enable: true, label: 'Start Free Trial', link: '/pricing' },
        button_secondary: { enable: true, label: 'Book a Demo', link: '/contact' },
        image: quickOfficeDashboard,
    },
    partners: {
        enable: true,
        badge: 'Trusted Platform',
        title: 'Powering thousands of <strong>local businesses</strong> worldwide',
    },
    smart_platform: {
        enable: true,
        title: 'Automate every part of your <br /> business with <strong>one smart platform.</strong>',
        cards: [
            {
                title: 'Automated Customer Follow-Up',
                subtitle: 'Never lose a lead again. Respond to inquiries instantly and automatically.',
                image: featureAutomatedMarketing,
                classNames: '',
            },
            {
                title: 'Autopilot Review Generator',
                subtitle: 'Automatically request and track 5-star Google reviews from happy clients.',
                image: featureAiPoweredGraph,
                classNames: '',
            },
            {
                title: 'Missed Call Auto-Responder',
                subtitle: 'Turn missed calls into booked appointments with instant automated text messages.',
                image: featureGrowYourEarnings,
                classNames: '',
            },
            {
                title: 'Unified Lead Inbox',
                subtitle: 'Manage all your SMS, email, Facebook, and Instagram messages in one single dashboard.',
                image: featureTurnoverTable,
                classNames: 'md:col-span-2 lg:col-span-2',
            },
            {
                title: '24/7 Appointment Scheduler',
                subtitle: 'Let customers book directly on your calendar, completely eliminating back-and-forth emails.',
                image: featureMarketingAutopilot,
                classNames: '',
            },
        ],
    },
    service_features: {
        enable: true,
        items: [
            {
                title: 'Built specifically to grow <strong>your local business</strong>',
                image: featureServiceFeature1,
                reverse: false,
                items: [
                    {
                        icon: 'FaBolt',
                        title: 'Setup in Minutes',
                        content: 'Get up and running immediately with our pre-built local business templates.',
                    },
                    {
                        icon: 'FaBrain',
                        title: 'Automated Intelligence',
                        content: 'Smart workflows that automatically sort, nurture and follow up with your leads.',
                    },
                    {
                        icon: 'FaLock',
                        title: 'Secure & Reliable',
                        content: 'Your client database and payment info is protected with bank-level encryption.',
                    },
                    {
                        icon: 'FaCubes',
                        title: 'All Tools In One Place',
                        content: 'Replace your CRM, website builder, calendar, and email marketing software.',
                    },
                ],
            },
            {
                title: 'The only software you need to <strong>scale predictably</strong>',
                image: featureServiceFeature2,
                reverse: true,
                items: [
                    {
                        icon: 'FaChartSimple',
                        title: 'Clear ROI Tracking',
                        content: 'See exactly which campaigns and ads are generating the most revenue.',
                    },
                    {
                        icon: 'FaRocket',
                        title: 'Easy to Use',
                        content: 'Designed for business owners, not IT professionals. Simple and intuitive.',
                    },
                    {
                        icon: 'FaShieldHalved',
                        title: 'Complete Client History',
                        content: 'View every text, email, and phone call with a client in a single chronological feed.',
                    },
                    {
                        icon: 'FaTableCellsLarge',
                        title: 'Mobile App Access',
                        content:
                            'Manage leads, reply to messages, and run your business from anywhere using our mobile app.',
                    },
                ],
            },
        ],
    },
};
---

<SiteLayout
    title="Features"
    description="Explore the powerful features Quick Office offers to automate and grow your local business."
>
    <!-- Banner -->
    <Section variant="ph" class="relative overflow-hidden pb-20">
        <Container class="relative">
            <div class="absolute top-0 left-0 w-full">
                <div class="h-100 w-full overflow-hidden -translate-y-10">
                    <canvas class="heroSporeCanvas w-full"></canvas>
                </div>
            </div>
            <div class="row justify-center">
                <div class="mb-20 text-center relative">
                    <h1
                        class="mb-8 lg:col-9 mx-auto text-h3 lg:text-h1 [&_strong]:text-primary"
                        set:html={markdownify(featuresData.banner.title)}
                    />
                    <p class="mb-10 lg:col-6 mx-auto text-lg">
                        {featuresData.banner.content}
                    </p>
                    <div class="flex gap-4 justify-center items-center flex-wrap">
                        <Button href={featuresData.banner.button_primary.link}>
                            {featuresData.banner.button_primary.label}
                        </Button>
                        <Button href={featuresData.banner.button_secondary.link} variant="outline">
                            {featuresData.banner.button_secondary.label}
                        </Button>
                    </div>
                </div>
                <div class="col-12">
                    <ImageMod src={featuresData.banner.image} alt="Quick Office Dashboard" class="w-full" />
                </div>
            </div>
        </Container>
    </Section>
    <hr class="border-border" />

    <!-- Trusted Partners -->
    <BrandsCarousel />

    <!-- Smart Platform Cards -->
    {
        featuresData.smart_platform.enable && (
            <Section class="mx-5 relative isolate overflow-hidden">
                <Container>
                    <div class="flex flex-col gap-10 lg:gap-16">
                        <div class="flex flex-col items-center gap-y-5 text-center">
                            <h2
                                class="mx-auto mb-2 text-h3 lg:col-10 lg:text-h2 [&_strong]:text-primary"
                                set:html={markdownify(featuresData.smart_platform.title)}
                            />
                        </div>
                        <div class="mb-0">
                            <div class="grid md:grid-cols-2 xl:grid-cols-3 grid-flow-dense gap-7">
                                {featuresData.smart_platform.cards.map((card: any) => (
                                    <ShowcaseCard
                                        title={card.title}
                                        subtitle={card.subtitle}
                                        image={card.image}
                                        classNames={card.classNames}
                                    />
                                ))}
                            </div>
                        </div>
                    </div>
                </Container>
                <GradientBlob />
            </Section>
        )
    }

    <!-- Service Features (alternating) -->
    {
        featuresData.service_features.enable &&
            featuresData.service_features.items.map((feature: any, index: number) => (
                <Section variant="sm" class="relative isolate">
                    <Container>
                        <div class="rounded-3xl bg-light/6 overflow-hidden">
                            <div class="grid lg:grid-cols-2">
                                <div class={`p-8 lg:p-12 xl:p-14 ${feature.reverse ? '' : 'lg:order-1'}`}>
                                    <h2
                                        class="text-h3-sm lg:text-h2 font-bold [&_strong]:text-primary mb-9 lg:mb-12"
                                        set:html={markdownify(feature.title)}
                                    />

                                    <div class="grid sm:grid-cols-2 gap-8 lg:gap-10">
                                        {feature.items.map((item: any) => (
                                            <article>
                                                <div class="size-10 rounded-xl bg-black/6 border border-border grid place-items-center mb-4">
                                                    <DynamicIcon icon={item.icon} className="text-text-light text-lg" />
                                                </div>
                                                <h3 class="text-h5-sm font-bold text-text-dark mb-2">{item.title}</h3>
                                                <p class="text-text">{item.content}</p>
                                            </article>
                                        ))}
                                    </div>
                                </div>

                                <div
                                    class={`p-8 lg:p-12 xl:p-14 bg-black/2 h-max ${feature.reverse ? '' : 'lg:order-0'}`}
                                >
                                    <ImageMod src={feature.image} alt={feature.title} class="w-full object-contain" />
                                </div>
                            </div>
                        </div>
                    </Container>
                    <GradientBlob />
                </Section>
            ))
    }

    <!-- Business Needs -->
    <BusinessNeeds />

    <!-- Comparison -->
    <ComparisonRow />

    <!-- FAQ -->
    <Faq />

    <!-- Call to Action -->
    <CallToAction />
</SiteLayout>

---
import { SiteLayout } from '@/layouts/site-layout';
import Badge from '@/components/Badge.astro';
import BrandsCarousel from '@/components/BrandsCarousel.astro';
import CallToAction from '@/components/CallToAction.astro';
import Faq from '@/components/Faq.astro';
import GradientBlob from '@/components/GradientBlob.astro';
import ImageMod from '@/components/ImageMod.astro';
import OurStory from '@/components/OurStory.astro';
import TeamCard from '@/components/TeamCard.astro';
import { markdownify } from '@/lib/utils/textConverter';
import Features from '@/components/partials/Features.astro';
import Testimonial from '@/components/partials/Testimonial.astro';
import {
    aboutHero,
    peopleProfile, peopleProfile1, peopleProfile2, peopleProfile3,
    iconInnovation, iconSecurity, iconCollaboration, iconResultDriven,
    iconCreativity, iconMembership, iconStarredFolder, featuresMenuIcon,
} from '@/lib/assets';

const aboutData = {
    page_header: {
        title: 'Your System-Driven <strong>Growth Partner.</strong>',
        subtitle: "We believe local businesses shouldn't have to hire a full-time IT department just to get more customers. We built this platform to put your growth on autopilot.",
        image: aboutHero,
    },
    stats: {
        enable: true,
        items: [
            { value: '10,000+', label: 'Local Businesses Served' },
            { value: '5M+', label: 'Leads Captured' },
            { value: '24/7', label: 'Automated Workflows' },
            { value: '99%', label: 'Platform Uptime' },
        ],
    },
    our_team: {
        enable: true,
        badge: 'Our Team',
        title: 'Meet Our <strong>Team Of Experts</strong>',
        members: [
            { image: peopleProfile, name: 'Josh Wangombe', role: 'Co-Founder & CTO' },
            { image: peopleProfile1, name: 'Daniel Jenson', role: 'Co-Founder & CEO' },
            { image: peopleProfile2, name: 'Toun Aalbers', role: 'Co-Founder & CTO' },
            { image: peopleProfile3, name: 'Peter van Ursel', role: 'Customer Success Director' },
        ],
    },
    core_values: {
        enable: true,
        badge: 'Our Core Mission',
        title: 'Empowering Local Businesses to <strong>Thrive and Scale</strong>',
        content: 'We replace the outdated, scattered tools with one powerful platform, so you can focus on what matters most: serving your clients and customers.',
        items: [
            { logo: iconInnovation, title: 'Simplicity First', is_starred: false },
            { logo: iconSecurity, title: 'Bank-Level Security', is_starred: false },
            { logo: iconCollaboration, title: 'Local Focus', is_starred: false },
            { logo: iconResultDriven, title: 'Results-Driven Tools', is_starred: false },
            { logo: iconCreativity, title: 'Automated Growth', is_starred: true },
            { logo: iconInnovation, title: 'Client-Centric', is_starred: false },
            { logo: iconMembership, title: 'No Hidden Fees', is_starred: false },
            { logo: iconStarredFolder, title: 'Reliable Support', is_starred: false },
            { logo: featuresMenuIcon, title: 'Continuous Updates', is_starred: false },
        ],
    },
};
---

<SiteLayout title="About Us" description="Learn about the team behind Quick Office and our mission to help local businesses grow.">
    <!-- Page Header -->
    <section class="section-ph pb-20 overflow-hidden">
        <div class="container">
            <div class="lg:max-w-4xl mx-auto text-center">
                <h1 class="hasHighlight mb-6" set:html={markdownify(aboutData.page_header.title)} />
                <p class="mb-5 text-lg text-text">{aboutData.page_header.subtitle}</p>
                <ImageMod
                    src={aboutData.page_header.image}
                    alt="Team collaboration meeting"
                    class="w-full h-auto object-cover aspect-video lg:aspect-1000/520 rounded-3xl mt-20"
                />
            </div>
            <div class="absolute inset-0 h-full w-full max-h-113 overflow-hidden -z-10">
                <canvas class="heroSporeCanvas w-full opacity-70"></canvas>
            </div>
        </div>
    </section>
    <hr class="border-border" />

    <BrandsCarousel />

    {
        aboutData.stats.enable && (
            <section class="section relative">
                <div class="container">
                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-2">
                        {aboutData.stats.items.map((stat) => (
                            <div class="text-center p-8 lg:p-10 lg:py-26 rounded-2xl bg-primary/10">
                                <div class="text-h2 lg:text-h1 leading-none font-bold font-secondary text-text-dark mb-4">
                                    {stat.value}
                                </div>
                                <p class="text-text text-h6">{stat.label}</p>
                            </div>
                        ))}
                    </div>
                </div>
                <div class="-translate-y-140">
                    <GradientBlob />
                </div>
            </section>
        )
    }

    <OurStory />

    {
        aboutData.our_team.enable && (
            <section class="section relative isolate overflow-hidden">
                <div class="container">
                    <div class="section-container">
                        <div class="section-intro centralize">
                            <Badge title={aboutData.our_team.badge} />
                            <h2 class="title hasHighlight" set:html={markdownify(aboutData.our_team.title)} />
                        </div>
                        <div class="section-content">
                            <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
                                {aboutData.our_team.members.map((member) => (
                                    <TeamCard image={member.image} name={member.name} role={member.role} />
                                ))}
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        )
    }

    {aboutData.core_values.enable && <Features our_features={aboutData.core_values} />}

    <Testimonial />
    <Faq />
    <CallToAction />
</SiteLayout>

---
import { SiteLayout } from '@/layouts/site-layout';
import { Badge, BrandsCarousel, CallToAction, Faq, GradientBlob, ImageMod } from '@/components';
import { OurStory, TeamCard, Features, Testimonial } from '@/screens/about';
import { Section } from '@/components/ui/section';
import { markdownify } from '@/lib/text-converter';
import {
    aboutHero,
    peopleProfile,
    peopleProfile1,
    peopleProfile2,
    peopleProfile3,
    iconInnovation,
    iconSecurity,
    iconCollaboration,
    iconResultDriven,
    iconCreativity,
    iconMembership,
    iconStarredFolder,
    featuresMenuIcon,
} from '@/lib/assets';

const aboutData = {
    page_header: {
        title: "The All-in-One Platform Built for <strong>Bangladesh's Local Businesses.</strong>",
        subtitle:
            'We started Quick Office because local entrepreneurs in Bangladesh deserved better tools — not expensive enterprise software locked behind complexity, but a smart, integrated platform that grows your business on autopilot.',
        image: aboutHero,
    },
    stats: {
        enable: true,
        items: [
            { value: '3,200+', label: 'Active Businesses' },
            { value: '৳85 Cr+', label: 'Revenue Tracked Monthly' },
            { value: '4.9/5', label: 'Customer Satisfaction' },
            { value: '99.9%', label: 'Platform Uptime' },
        ],
    },
    our_team: {
        enable: true,
        badge: 'Our Team',
        title: 'Meet the People <strong>Behind Quick Office</strong>',
        members: [
            { image: peopleProfile, name: 'Rahim Chowdhury', role: 'Co-Founder & CEO' },
            { image: peopleProfile1, name: 'Tasneem Haque', role: 'Co-Founder & CTO' },
            { image: peopleProfile2, name: 'Farhan Kabir', role: 'Head of Product' },
            { image: peopleProfile3, name: 'Sadia Afrin', role: 'Head of Customer Success' },
        ],
    },
    core_values: {
        enable: true,
        badge: 'Our Core Values',
        title: 'Built on Principles That <strong>Put You First</strong>',
        content:
            'Every feature in Quick Office exists for one reason: to make your business easier to run, so you can focus on your customers — not your software.',
        items: [
            { logo: iconInnovation, title: 'Radically Simple', is_starred: false },
            { logo: iconSecurity, title: 'Bank-Level Security', is_starred: false },
            { logo: iconCollaboration, title: 'Built for Bangladesh', is_starred: false },
            { logo: iconResultDriven, title: 'Results-Driven Tools', is_starred: false },
            { logo: iconCreativity, title: 'Automated Growth', is_starred: true },
            { logo: iconInnovation, title: 'Client-First Support', is_starred: false },
            { logo: iconMembership, title: 'No Hidden Fees', is_starred: false },
            { logo: iconStarredFolder, title: 'Always Improving', is_starred: false },
            { logo: featuresMenuIcon, title: 'Local Expertise', is_starred: false },
        ],
    },
};
---

<SiteLayout
    title="About Us"
    description="Learn about the team behind Quick Office and our mission to help local businesses grow."
>
    <!-- Page Header -->
    <Section variant="ph" class="pb-20 overflow-hidden">
        <div class="container">
            <div class="lg:max-w-4xl mx-auto text-center">
                <h1 class="[&_strong]:text-primary mb-6" set:html={markdownify(aboutData.page_header.title)} />
                <p class="mb-5 text-lg text-text">{aboutData.page_header.subtitle}</p>
                <ImageMod
                    src={aboutData.page_header.image}
                    alt="Team collaboration meeting"
                    class="w-full h-auto object-cover aspect-video lg:aspect-1000/520 rounded-3xl mt-20"
                />
            </div>
            <div class="absolute inset-0 h-full w-full max-h-113 overflow-hidden -z-10">
                <canvas class="heroSporeCanvas w-full opacity-70"></canvas>
            </div>
        </div>
    </Section>
    <hr class="border-border" />

    <BrandsCarousel />

    {
        aboutData.stats.enable && (
            <Section class="relative">
                <div class="container">
                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-2">
                        {aboutData.stats.items.map((stat) => (
                            <div class="text-center p-8 lg:p-10 lg:py-26 rounded-2xl bg-primary/10">
                                <div class="text-h2 lg:text-h1 leading-none font-bold font-secondary text-text-dark mb-4">
                                    {stat.value}
                                </div>
                                <p class="text-text text-h6">{stat.label}</p>
                            </div>
                        ))}
                    </div>
                </div>
                <div class="-translate-y-140">
                    <GradientBlob />
                </div>
            </Section>
        )
    }

    <OurStory />

    {
        aboutData.our_team.enable && (
            <Section class="relative isolate overflow-hidden">
                <div class="container">
                    <div class="flex flex-col gap-10 lg:gap-16">
                        <div class="flex flex-col items-center gap-y-5 text-center">
                            <Badge title={aboutData.our_team.badge} />
                            <h2
                                class="mx-auto mb-2 text-h3 lg:col-10 lg:text-h2 [&_strong]:text-primary"
                                set:html={markdownify(aboutData.our_team.title)}
                            />
                        </div>
                        <div class="mb-0">
                            <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
                                {aboutData.our_team.members.map((member) => (
                                    <TeamCard image={member.image} name={member.name} role={member.role} />
                                ))}
                            </div>
                        </div>
                    </div>
                </div>
            </Section>
        )
    }

    {aboutData.core_values.enable && <Features our_features={aboutData.core_values} />}

    <Testimonial />
    <Faq />
    <CallToAction />
</SiteLayout>

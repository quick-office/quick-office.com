---
import { SiteLayout } from '@/layouts/site-layout';
import { CallToAction, Faq, PageHeader } from '@/components';
import { Button } from '@/components/ui/button';
import DynamicIcon from '@/components/helpers/DynamicIcon';

const contactData = {
    page_header: {
        title: 'Have a question? <strong>Send us a message</strong>',
        subtitle:
            'Our team is here to help. Whether you want to learn more about the Missed Call Auto-Responder, or how to set up your Unified Inbox, our support team is ready to assist you.',
    },
    contact_info: {
        enable: true,
        items: [
            {
                type: 'calendar',
                title: 'Book A Demo',
                detail: 'Schedule your one-on-one setup call',
                link: '',
                icon: 'FaCalendarCheck',
            },
            {
                type: 'email',
                title: 'Email Us',
                detail: 'hello@yoursoftware.com',
                link: 'mailto:hello@yoursoftware.com',
                icon: 'FaEnvelope',
            },
            {
                type: 'phone',
                title: 'Call or Text Us',
                detail: '+1 (800) 123-4567',
                link: 'tel:+18001234567',
                icon: 'FaPhone',
            },
        ],
    },
};
---

<SiteLayout title="Contact Us" description="Get in touch with Quick Office. We're here to help your business grow.">
    <PageHeader title={contactData.page_header.title} subtitle={contactData.page_header.subtitle} />

    <!-- Contact Section -->
    <section class="section pt-0">
        <div class="container">
            <div class="row g-7 max-lg:gap-5">
                <!-- Left Column - Contact Cards -->
                <div class="col-12 lg:col-5">
                    <div class="flex flex-col gap-5">
                        {
                            contactData.contact_info?.enable &&
                                contactData.contact_info.items.map((item) => {
                                    const Container = item.type === 'calendar' ? 'div' : 'a';
                                    const href =
                                        item.link ||
                                        (item.type === 'email'
                                            ? `mailto:${item.detail}`
                                            : item.type === 'phone'
                                              ? `tel:${item.detail}`
                                              : undefined);

                                    return (
                                        <Container
                                            href={Container === 'a' ? href : undefined}
                                            class={`flex flex-col gap-5 p-7 md:p-8 bg-black/5 rounded-2xl cursor-pointer hover:bg-black/10 transition-all duration-300 ring-1 ring-black/10 hover:ring-primary/50 group hover:scale-[1.02]`}
                                            data-ghl-trigger={item.type === 'calendar' ? 'true' : undefined}
                                        >
                                            <div class="w-10 h-10 flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
                                                <DynamicIcon
                                                    icon={item.icon ?? ''}
                                                    className="w-10 h-10 text-text-dark"
                                                />
                                            </div>
                                            <div class="flex flex-col gap-3">
                                                <h3 class="font-secondary font-bold text-2xl text-text-dark">
                                                    {item.title}
                                                </h3>
                                                <p class="text-text text-lg">{item.detail}</p>
                                            </div>
                                        </Container>
                                    );
                                })
                        }
                    </div>
                </div>

                <!-- Right Column - Contact Form -->
                <div class="col-12 lg:col-7">
                    <div class="p-8 md:p-10 bg-black/5 rounded-2xl">
                        <form id="contact-form" novalidate class="flex flex-col gap-10">
                            <div class="flex flex-col gap-5">
                                <div class="relative">
                                    <input
                                        type="text"
                                        name="name"
                                        placeholder="Name"
                                        required
                                        class="w-full rounded-full bg-black/5 backdrop-blur-[44px] px-8 py-5 border border-border text-text-dark placeholder:text-text-dark focus:border-primary focus:outline-none transition-colors"
                                    />
                                </div>
                                <div class="relative">
                                    <input
                                        type="email"
                                        name="email"
                                        placeholder="Email Address"
                                        required
                                        class="w-full rounded-full bg-black/5 backdrop-blur-[44px] px-8 py-5 border border-border text-text-dark placeholder:text-text-dark focus:border-primary focus:outline-none transition-colors"
                                    />
                                </div>
                                <div class="relative">
                                    <input
                                        type="tel"
                                        name="phone"
                                        placeholder="Phone number"
                                        required
                                        class="w-full rounded-full bg-black/5 backdrop-blur-[44px] px-8 py-5 border border-border text-text-dark placeholder:text-text-dark focus:border-primary focus:outline-none transition-colors"
                                    />
                                </div>
                                <div class="relative">
                                    <textarea
                                        name="message"
                                        placeholder="Write your message..."
                                        rows={4}
                                        required
                                        class="w-full rounded-[20px] bg-black/5 backdrop-blur-[44px] px-8 py-5 border border-border text-text-dark placeholder:text-text-dark focus:border-primary focus:outline-none transition-colors resize-none"
                                    ></textarea>
                                </div>
                            </div>
                            <div class="flex flex-col gap-6">
                                <!-- Status messages -->
                                <div
                                    id="form-success"
                                    class="hidden rounded-2xl bg-green-500/10 border border-green-500/30 px-6 py-4 text-green-400 text-base"
                                >
                                    ✅ Message sent! We'll be in touch shortly.
                                </div>
                                <div
                                    id="form-error"
                                    class="hidden rounded-2xl bg-red-500/10 border border-red-500/30 px-6 py-4 text-red-400 text-base"
                                >
                                    ⚠️ <span id="form-error-text">Something went wrong. Please try again.</span>
                                </div>

                                <Button
                                    type="submit"
                                    id="contact-submit"
                                    class="w-full py-4 text-lg font-medium disabled:opacity-60 disabled:cursor-not-allowed"
                                >
                                    <span id="submit-label">Send Message</span>
                                    <span id="submit-loading" class="hidden">Sending…</span>
                                </Button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <Faq />

    <!-- Call to Action -->
    <CallToAction />
</SiteLayout>

<script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
    const submitLabel = document.getElementById('submit-label');
    const submitLoading = document.getElementById('submit-loading');
    const successEl = document.getElementById('form-success');
    const errorEl = document.getElementById('form-error');
    const errorText = document.getElementById('form-error-text');

    function setLoading(loading: boolean) {
        if (!submitBtn || !submitLabel || !submitLoading) return;
        submitBtn.disabled = loading;
        submitLabel.classList.toggle('hidden', loading);
        submitLoading.classList.toggle('hidden', !loading);
    }

    function showSuccess() {
        successEl?.classList.remove('hidden');
        errorEl?.classList.add('hidden');
        form?.reset();
    }

    function showError(msg?: string) {
        errorEl?.classList.remove('hidden');
        successEl?.classList.add('hidden');
        if (errorText && msg) errorText.textContent = msg;
    }

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Hide previous status
        successEl?.classList.add('hidden');
        errorEl?.classList.add('hidden');

        const formData = new FormData(form);
        setLoading(true);

        try {
            // TODO: send formData to a backend here (CRM integration removed)
            void formData;
            showSuccess();
        } catch {
            showError('Something went wrong. Please try again.');
        } finally {
            setLoading(false);
        }
    });
</script>

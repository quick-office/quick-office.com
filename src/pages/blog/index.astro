---
import { SiteLayout } from '@/layouts/site-layout';
import BlogCard from '@/components/BlogCard.astro';
import CallToAction from '@/components/CallToAction.astro';
import FeaturedPostCard from '@/components/FeaturedPostCard.astro';
import ImageMod from '@/components/ImageMod.astro';
import { blogFeaturedCover, blogAuthor1, blogPost1 } from '@/lib/assets';
import { getSinglePage } from '@/lib/contentParser.astro';
import dateFormat from '@/lib/utils/dateFormat';
import { sortByDate } from '@/lib/utils/sortFunctions';
import { markdownify } from '@/lib/utils/textConverter';

const pageData = {
    page_header: {
        title: 'Stay Informed With Our <strong>Latest Insights</strong>',
        featured_post: 'human-touch-ai-marketing',
    },
    featured_post: { enable: true },
    latest_posts: { enable: true, title: 'Latest Local Business Strategies' },
};

const allPosts = sortByDate(await getSinglePage('blog'));

const featuredId = pageData.page_header.featured_post;
const featuredPost = featuredId ? (allPosts.find((p) => p.id === featuredId) ?? allPosts[0]) : allPosts[0];
const latestPosts = allPosts.filter((p) => p.id !== featuredPost.id);
---

<SiteLayout title="Blog" description="Stay informed with the latest insights and guides on getting more local customers on autopilot.">
    <!-- Page Header -->
    <section class="section-ph pb-10 relative">
        <div class="container relative">
            <div class="absolute top-0 left-0 w-full">
                <div class="h-100 w-full overflow-hidden -translate-y-10">
                    <canvas class="heroSporeCanvas w-full opacity-70"></canvas>
                </div>
            </div>
            <div class="lg:max-w-4xl mx-auto text-center relative z-10">
                <h1 class="hasHighlight mb-0" set:html={markdownify(pageData.page_header.title)} />
            </div>
        </div>
    </section>

    <!-- Featured Article -->
    {
        pageData.featured_post.enable && (
            <section class="section pt-0">
                <div class="container">
                    <div class="grid gap-4 lg:grid-cols-[1fr_1.03fr]">
                        <div class="overflow-hidden rounded-2xl border border-white/10">
                            <ImageMod
                                src={featuredPost.data.image ?? blogFeaturedCover}
                                alt={featuredPost.data.title}
                                width={700}
                                height={500}
                                class="h-full w-full object-cover"
                            />
                        </div>
                        <FeaturedPostCard
                            tag={featuredPost.data.tag ?? 'Popular'}
                            title={featuredPost.data.title}
                            description={featuredPost.data.description ?? ''}
                            authorImage={featuredPost.data.author_image ?? blogAuthor1}
                            authorName={featuredPost.data.author}
                            date={dateFormat(featuredPost.data.date ?? new Date())}
                            readTime={featuredPost.data.read_time ?? '5 min read'}
                            href={`/blog/${featuredPost.id}`}
                        />
                    </div>

                    <hr class="mt-16 border-border" />
                </div>
            </section>
        )
    }

    <!-- Latest Articles -->
    {
        pageData.latest_posts.enable && (
            <section class="section pt-10 lg:pt-14">
                <div class="container relative isolate">
                    <div class="mb-12 text-center">
                        <h2 class="text-h3-sm md:text-h2 capitalize">
                            {pageData.latest_posts.title}
                        </h2>
                    </div>

                    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
                        {latestPosts.map((post) => (
                            <BlogCard
                                image={post.data.image ?? blogPost1}
                                imageAlt={post.data.title}
                                title={post.data.title}
                                description={post.data.description ?? ''}
                                authorImage={post.data.author_image ?? blogAuthor1}
                                authorName={post.data.author}
                                date={dateFormat(post.data.date ?? new Date())}
                                href={`/blog/${post.id}`}
                            />
                        ))}
                    </div>
                </div>
            </section>
        )
    }

    <!-- Call to Action -->
    <CallToAction />
</SiteLayout>

---
import { Banner } from '@/screens/home/banner';
import { SiteLayout } from '@/layouts/site-layout';

import SocialProof from '@/screens/home/SocialProof.astro';
import PainPoints from '@/screens/home/PainPoints.astro';
import ValueProps from '@/screens/home/ValueProps.astro';
import FeaturesGrid from '@/screens/home/FeaturesGrid.astro';
import HowItWorks from '@/screens/home/HowItWorks.astro';
import Comparison from '@/screens/home/Comparison.astro';

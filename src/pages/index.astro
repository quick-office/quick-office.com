---
import config from '@/config/config.json';

import Base from '@/layouts/Base.astro';
import Banner from '@/screens/home/banner/Banner.astro';
import SocialProof from '@/screens/home/SocialProof.astro';
import PainPoints from '@/screens/home/PainPoints.astro';
import ValueProps from '@/screens/home/ValueProps.astro';
import FeaturesGrid from '@/screens/home/FeaturesGrid.astro';
import HowItWorks from '@/screens/home/HowItWorks.astro';
import Comparison from '@/screens/home/Comparison.astro';
import Pricing from '@/screens/home/Pricing.astro';
import TestimonialsAndFaq from '@/screens/home/TestimonialsAndFaq.astro';
import Cta from '@/screens/home/Cta.astro';
---

<Base title={config.site.home_title}>
    <Banner />
    <hr class="border-border" />
    <SocialProof />
    <hr class="border-border" />
    <PainPoints />
    <hr class="border-border" />
    <ValueProps />
    <FeaturesGrid />
    <HowItWorks />
    <Comparison />
    <Pricing />
    <hr class="border-border" />
    <TestimonialsAndFaq />
    <Cta />
</Base>

---
import { SiteLayout } from '@/layouts/site-layout';
import { Button } from '@/components/ui/button';
import { Section } from '@/components/ui/section';
---

<SiteLayout title="Page Not Found" description="The page you are looking for could not be found.">
    <Section variant="ph" class="text-center relative overflow-hidden">
        <div class="container relative">
            <div class="absolute top-0 left-0 w-full">
                <div class="h-100 w-full overflow-hidden -translate-y-10">
                    <canvas class="heroSporeCanvas w-full"></canvas>
                </div>
            </div>

            <div class="row justify-center">
                <div class="sm:col-10 md:col-8 lg:col-6">
                    <span class="text-[8rem] block font-bold text-primary"> 404 </span>
                    <h1 class="h2 mb-4">Page not found</h1>
                    <div class="content">
                        <p>
                            The page you are looking for might have been removed, had its name changed, or is
                            temporarily unavailable.
                        </p>
                    </div>
                    <Button href="/" class="mt-8">Back to home</Button>
                </div>
            </div>
        </div>
    </Section>
</SiteLayout>

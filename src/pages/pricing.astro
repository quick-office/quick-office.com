---
import { SiteLayout } from '@/layouts/site-layout';
import Badge from '@/components/Badge.astro';
import CallToAction from '@/components/CallToAction.astro';
import Faq from '@/components/Faq.astro';
import PricingSection from '@/components/PricingSection.astro';
import { markdownify } from '@/lib/text-converter';

const pricingData = {
    page_header: {
        badge: 'Pricing',
        title: 'Pricing Built For Local Business Growth',
        content: 'Start your free 14-day trial, scale as you grow. No contracts. Cancel anytime.',
    },
    comparison: {
        enable: true,
        badge: 'Plan Matrix',
        title: 'Pricing Plans <strong>Comparison</strong>',
        headers: [{ label: 'Features' }, { label: 'Essentials' }, { label: 'Growth' }, { label: 'Scale' }],
        rows: [
            { feature: 'Monthly Price', values: ['$97', '$297', '$497'] },
            { feature: 'User Accounts', values: ['3', '10', 'Unlimited'] },
            { feature: 'Unified Lead Inbox', values: [true, true, true] },
            { feature: 'Missed Call Auto-Responder', values: [true, true, true] },
            { feature: 'Autopilot Review Generator', values: [true, true, true] },
            { feature: '24/7 Appointment Scheduler', values: [false, true, true] },
            { feature: 'Website & Funnel Builder', values: [false, true, true] },
            { feature: 'Automated SMS/Email Campaigns', values: [false, true, true] },
            { feature: 'Multi-Location Management', values: [false, false, true] },
            { feature: 'Support', values: ['Email Support', 'Priority Support', 'Dedicated Manager'] },
        ],
    },
};
---

<SiteLayout title="Pricing" description="Simple, transparent pricing plans for businesses of every size.">
    <!-- Page Header -->
    <section class="section-ph pb-0 relative overflow-hidden">
        <div class="container relative">
            <div class="absolute top-0 left-0 w-full">
                <div class="h-100 w-full overflow-hidden -translate-y-10">
                    <canvas class="heroSporeCanvas w-full"></canvas>
                </div>
            </div>
            <div class="row justify-center">
                <div class="mb-10 text-center relative z-10">
                    <h1
                        class="mb-6 lg:col-9 mx-auto text-h3 lg:text-h1 hasHighlight"
                        set:html={markdownify(pricingData.page_header.title)}
                    />
                    <p class="mb-10 lg:col-6 mx-auto text-text-light text-base">
                        {pricingData.page_header.content}
                    </p>
                </div>
            </div>
        </div>

        <PricingSection isHome={false} />
    </section>

    <!-- Comparison Table -->
    {
        pricingData.comparison.enable && (
            <section class="section relative isolate overflow-hidden">
                <div class="container">
                    <div class="section-container">
                        <div class="section-intro centralize">
                            <Badge title={pricingData.comparison.badge} />
                            <h2 class="title hasHighlight" set:html={markdownify(pricingData.comparison.title)} />
                        </div>
                        <div class="section-content">
                            <div class="overflow-x-auto">
                                <div class="relative min-w-275 overflow-hidden rounded-3xl border border-border/80 bg-light/70 text-text shadow-[0_24px_80px_rgba(0,0,0,0.35)] backdrop-blur-md">
                                    <div class="grid grid-cols-[1.2fr_1fr_1fr_1fr] items-center text-sm md:text-base font-primary text-text relative z-10">
                                        {pricingData.comparison.headers.map((h: any, i: number) => (
                                            <div
                                                class={`px-6 py-5 text-h5-sm font-semibold text-text-dark ${i === 0 ? '' : 'text-center'}`}
                                            >
                                                {h.label}
                                            </div>
                                        ))}
                                    </div>

                                    <div class="relative z-10">
                                        {pricingData.comparison.rows.map((row: any, i: number) => (
                                            <div
                                                class={`grid grid-cols-[1.2fr_1fr_1fr_1fr] items-center border-t border-border/60 ${i % 2 === 0 ? 'bg-black/5' : ''}`}
                                            >
                                                <div class="px-6 py-4 text-text-dark">{row.feature}</div>
                                                {row.values.map((val: any, valIndex: number) => (
                                                    <div class="px-6 py-4 text-center">
                                                        {typeof val === 'boolean' ? (
                                                            val ? (
                                                                <span class="inline-flex h-6 w-6 items-center justify-center rounded-md bg-primary/80 shadow-[0_8px_18px_rgba(147,122,255,0.35)]">
                                                                    <svg
                                                                        class="h-4 w-4 text-text-dark"
                                                                        viewBox="0 0 24 24"
                                                                        fill="none"
                                                                        stroke="currentColor"
                                                                        stroke-width="3"
                                                                        stroke-linecap="round"
                                                                        stroke-linejoin="round"
                                                                        aria-hidden="true"
                                                                    >
                                                                        <polyline points="20 6 9 17 4 12" />
                                                                    </svg>
                                                                </span>
                                                            ) : (
                                                                <span class="inline-flex h-6 w-6 items-center justify-center rounded-md bg-black/10 ring-1 ring-border/60">
                                                                    <span class="block h-0.5 w-3 rounded-full bg-black/60" />
                                                                </span>
                                                            )
                                                        ) : (
                                                            <span
                                                                class={`font-medium ${valIndex === 1 ? 'text-text-dark' : 'text-text-dark'}`}
                                                            >
                                                                {val}
                                                            </span>
                                                        )}
                                                    </div>
                                                ))}
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        )
    }

    <!-- FAQ -->
    <Faq />

    <!-- Call to Action -->
    <CallToAction />
</SiteLayout>

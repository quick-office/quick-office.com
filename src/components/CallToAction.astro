---
import Badge from './Badge.astro';
import { Button } from '@/components/ui/button';
import { markdownify } from '@/lib/text-converter';

const cta = {
    enable: true,
    badge: 'Get Started Today',
    title: 'Ready to take control of your <strong>business finances?</strong>',
    description: 'Join hundreds of businesses using Quick Office. Start free, no card required.',
    button: {
        enable: true,
        label: 'Start My Free Trial',
        link: '/pricing',
    },
};
---

{
    cta.enable && (
        <section class="section">
            <div class="container bg-light py-20 rounded-4xl relative overflow-hidden isolate">
                <div class="section-container">
                    <div class="section-intro centralize">
                        <Badge title={cta.badge} />
                        <h2 class="title hasHighlight lg:col-7" set:html={markdownify(cta.title)} />
                        <p class="subtitle text-h6-sm lg:col-6">{cta.description}</p>
                        {cta.button.enable && cta.button.link && (
                            <Button href={cta.button.link} class="mt-9">
                                {cta.button.label}
                            </Button>
                        )}
                    </div>
                </div>
                <div class="absolute top-1/2 -translate-y-1/2 h-1/2 w-full overflow-hidden">
                    <canvas class="heroSporeCanvas w-full" />
                </div>
            </div>
        </section>
    )
}

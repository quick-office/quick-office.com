---
import { markdownify } from '@/lib/text-converter';
import { brandDropbox, brandHubspot, brandLivechat, brandPingdom, brandScapic } from '@/lib/assets';

const brands = {
    enable: true,
    title: 'Trusted by <strong class="text-primary">500+</strong> businesses across Bangladesh to manage their finances.',
    images: [
        { src: brandDropbox.src, alt: 'Dropbox' },
        { src: brandHubspot.src, alt: 'HubSpot' },
        { src: brandLivechat.src, alt: 'LiveChat' },
        { src: brandPingdom.src, alt: 'Pingdom' },
        { src: brandScapic.src, alt: 'Scapic' },
    ],
};

const brandUrls = brands.images.map((img) => img.src);
---

{
    brands.enable && (
        <section class="section-sm pt-16 xl:pt-20">
            <div class="container">
                <div class="text-center mb-10">
                    <p class="text-text-light text-base" set:html={markdownify(brands.title)} />
                </div>
                <div
                    class="flex gap-10 xl:gap-x-16 flex-wrap justify-center items-center [&>img]:lg:h-8"
                    data-trusted-brands-images={JSON.stringify(brandUrls)}
                >
                    {/* Handled by script: main.js updateTrustedPartners() */}
                </div>
            </div>
        </section>
    )
}

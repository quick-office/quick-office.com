---
import ImageMod from '@/components/ImageMod.astro';
import { Button } from '@/components/ui/button';
import { Section } from '@/components/ui/section';
import { markdownify } from '@/lib/text-converter';
import { Container } from '@/components/ui/container';

interface Props {
    lead_generation: any;
}

const { lead_generation } = Astro.props;
---

<Section variant="box" class="bg-transparent my-0 pb-0">
    <Container sm>
        <div class="flex flex-col gap-10 lg:gap-16 pb-20">
            <div class="flex flex-col items-center gap-y-5 text-center">
                <h2
                    class="mx-auto mb-2 text-h3 lg:col-10 lg:text-h2 [&_strong]:text-primary"
                    set:html={lead_generation.title}
                />
            </div>
            <div class="mb-0">
                <div class="flex flex-col-reverse lg:flex-row gap-x-20 gap-y-10">
                    <div class="lg:w-6/12">
                        <h3 class="text-h5-sm font-bold mb-7">
                            {lead_generation.subtitle}
                        </h3>
                        <div class="space-y-4" set:html={markdownify(lead_generation.content, true)} />
                        <ul class="list-none pl-0 mt-10">
                            {
                                lead_generation.list.map((item: string) => (
                                    <li class="relative pl-6 mb-8">
                                        <svg
                                            class="absolute left-0 top-0 mt-0.5 size-4 translate-y-[4px]"
                                            width="20"
                                            height="20"
                                            viewBox="0 0 20 20"
                                            fill="none"
                                            xmlns="http://www.w3.org/2000/svg"
                                            aria-hidden="true"
                                        >
                                            <path
                                                fill="#28C114"
                                                fill-rule="evenodd"
                                                d="M1.042 10a8.958 8.958 0 1 0 17.916 0 8.958 8.958 0 0 0-17.916 0Zm12.854-3.114c.34.311.363.838.052 1.177l-4.584 5a.834.834 0 0 1-1.203.027l-2.084-2.084a.833.833 0 1 1 1.179-1.178l1.468 1.468 3.995-4.359a.833.833 0 0 1 1.177-.051Z"
                                                clip-rule="evenodd"
                                            />
                                        </svg>
                                        <span set:html={markdownify(item)} />
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                    <div class="lg:w-6/12">
                        <div class="bg-light rounded-4xl corner-squircle p-10 xl:px-7.5 xl:py-10">
                            <ImageMod
                                src={lead_generation.image}
                                width={307}
                                height={190}
                                alt="ebook"
                                class="w-full max-w-76.75 mx-auto mb-12"
                            />
                            <form id="lead-form" novalidate class="">
                                <div class="form-control">
                                    <input
                                        type="text"
                                        name="name"
                                        placeholder="Name"
                                        class="w-full rounded-full border border-border bg-light px-7 py-5 text-text-dark placeholder:text-text focus:border-primary focus:ring-transparent mb-5"
                                        required
                                    />
                                    <input
                                        type="email"
                                        name="email"
                                        placeholder="Email Address"
                                        class="w-full rounded-full border border-border bg-light px-7 py-5 text-text-dark placeholder:text-text focus:border-primary focus:ring-transparent mb-5"
                                        required
                                    />
                                    <Button
                                        type="submit"
                                        id="lead-submit"
                                        class="w-full disabled:opacity-60 disabled:cursor-not-allowed"
                                    >
                                        <span id="lead-submit-label">Get Free Checklist</span>
                                        <span id="lead-submit-loading" class="hidden">Submitting...</span>
                                    </Button>
                                    <div
                                        id="lead-form-success"
                                        class="hidden mt-4 text-green-500 font-medium text-sm text-center"
                                    >
                                        ✅ Free Checklist requested successfully!
                                    </div>
                                    <div
                                        id="lead-form-error"
                                        class="hidden mt-4 text-red-500 font-medium text-sm text-center"
                                    >
                                        ⚠️ <span id="lead-form-error-text">Something went wrong.</span>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Container>
    <hr class="border-border" />
</Section>

<script>
    const form = document.getElementById('lead-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('lead-submit') as HTMLButtonElement | null;
    const submitLabel = document.getElementById('lead-submit-label');
    const submitLoading = document.getElementById('lead-submit-loading');
    const successEl = document.getElementById('lead-form-success');
    const errorEl = document.getElementById('lead-form-error');
    const errorText = document.getElementById('lead-form-error-text');

    function setLoading(loading: boolean) {
        if (!submitBtn || !submitLabel || !submitLoading) return;
        submitBtn.disabled = loading;
        submitLabel.classList.toggle('hidden', loading);
        submitLoading.classList.toggle('hidden', !loading);
    }

    function showSuccess() {
        successEl?.classList.remove('hidden');
        errorEl?.classList.add('hidden');
        form?.reset();
    }

    function showError(msg?: string) {
        errorEl?.classList.remove('hidden');
        successEl?.classList.add('hidden');
        if (errorText && msg) errorText.textContent = msg;
    }

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Hide previous status
        successEl?.classList.add('hidden');
        errorEl?.classList.add('hidden');

        const formData = new FormData(form);
        setLoading(true);

        try {
            // TODO: send formData to a backend here (CRM integration removed)
            void formData;
            showSuccess();
        } catch {
            showError('Something went wrong. Please try again.');
        } finally {
            setLoading(false);
        }
    });
</script>

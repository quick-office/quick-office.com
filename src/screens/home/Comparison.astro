---
import ImageMod from '@/components/ImageMod.astro';
import { Section } from '@/components/ui/section';
import { platformAbleton, platformAirbnb, platformFacebook, platformFigma, platformSlack } from '@/lib/assets';
import { Container } from '@/components/ui/container';

const items = [
    {
        title: 'Tally + Excel + Separate Payroll',
        price: '৳8,000+',
        images: [platformAbleton, platformAirbnb],
    },
    {
        title: 'Enterprise Accounting Suite',
        price: '৳15,000+',
        images: [platformFacebook, platformFigma],
    },
    {
        title: 'Quick Office (All-in-One)',
        price: '৳1,999',
        images: [platformSlack],
    },
];
---

<Section class="relative isolate overflow-x-hidden">
    <div class="absolute inset-0 -z-20 pointer-events-none bg-body"></div>
    <div class="absolute inset-0 -z-10 pointer-events-none pattern-stripes opacity-25"></div>
    <div
        class="absolute inset-0 -z-10 pointer-events-none bg-gradient-to-b from-transparent via-primary/8 to-transparent"
    >
    </div>
    <Container>
        <div class="flex flex-col gap-10 lg:gap-16">
            <div class="flex flex-col items-center gap-y-5 text-center">
                <h2 class="mx-auto mb-2 text-h3 lg:col-10 lg:text-h2 [&_strong]:text-primary">
                    One Tool. <strong>Replace Them All.</strong>
                </h2>
            </div>
            <div class="mb-0">
                <div class="flex flex-col gap-y-5 px-4">
                    {
                        items.map(({ title, price, images }) => (
                            <div class="relative max-lg:border max-lg:border-border max-lg:rounded-4xl max-lg:py-8 max-lg:corner-squircle">
                                <div class="flex items-center flex-col lg:flex-row lg:justify-between w-full gap-y-8">
                                    <div class="bg-body border border-border px-4 w-full py-2.5 rounded-full flex items-center justify-center relative z-10 gap-x-2 max-w-70">
                                        <span class="font-semibold text-text-dark text-lg">{title}</span>
                                    </div>
                                    <div class="flex items-center justify-start gap-3 xl:gap-5 lg:min-w-90">
                                        {images.map((src) => (
                                            <ImageMod src={src} alt={`${title} icon`} class="max-h-12" />
                                        ))}
                                    </div>
                                    <div class="bg-body border border-border px-4 w-full py-2.5 rounded-full flex items-center justify-center relative z-10 gap-x-2 max-w-60">
                                        <span class="font-normal text-text text-base">
                                            <span class="text-secondary font-secondary font-bold text-h6">{price}</span>{' '}
                                            /Per Month
                                        </span>
                                    </div>
                                </div>
                                <div class="absolute inset-0 items-center -z-10 hidden xl:flex">
                                    <div class="border-t border-border border-dashed w-full" />
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </Container>
</Section>

<style>
    .pattern-stripes {
        background-image: url("data:image/svg+xml,%3Csvg width='10' height='10' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 10L10 0M-2.5 2.5L2.5 -2.5M7.5 12.5L12.5 7.5' stroke='%23b8c6d6' stroke-width='1'/%3E%3C/svg%3E");
        background-size: 10px 10px;
    }
</style>

---
import ValueCard from '@/screens/home/ValueCard.astro';
import { valuesIcon1, valuesIcon2, valuesIcon3, valuesIcon4 } from '@/lib/assets';

const items = [
    {
        logo: valuesIcon1,
        title: 'Sales & Invoicing',
        list: [
            'Create & send professional invoices',
            'Track payment status in real time',
            'Full payment receive history',
        ],
    },
    {
        logo: valuesIcon2,
        title: 'Procurement & Payments',
        list: ['Manage all supplier invoices', 'Process & record supplier payments', 'Complete payment history log'],
    },
    {
        logo: valuesIcon3,
        title: 'Accounting & Vouchers',
        list: ['Full chart of accounts', 'Debit/credit voucher creation', 'Journal book & account book'],
    },
    {
        logo: valuesIcon4,
        title: 'Reports & Insights',
        list: ['Profit & loss summary', 'Cost center analysis', 'Account distribution overview'],
    },
];
---

<section class="section relative overflow-hidden">
    <div class="absolute inset-0 -z-20 pointer-events-none bg-body"></div>
    <div class="absolute inset-0 -z-10 pointer-events-none pattern-hlines opacity-30"></div>
    <div
        class="absolute inset-0 -z-10 pointer-events-none bg-gradient-to-r from-primary/10 via-transparent to-transparent"
    >
    </div>
    <div class="container">
        <div class="section-container">
            <div class="section-intro centralize">
                <h2 class="title hasHighlight">One Platform. <strong>Every Financial Workflow.</strong></h2>
                <p class="subtitle">Log in to a single dashboard to run your entire financial operation.</p>
            </div>
            <div class="section-content">
                <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-2">
                    {items.map((item) => <ValueCard logo={item.logo} title={item.title} list={item.list} />)}
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .pattern-hlines {
        background-image: url("data:image/svg+xml,%3Csvg width='40' height='16' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 8h40' stroke='%23c7d2e0' stroke-width='1'/%3E%3C/svg%3E");
        background-size: 40px 16px;
    }
</style>

---
import { brandDropbox, brandHubspot, brandLivechat, brandPingdom, brandScapic } from '@/lib/assets';

const brandUrls = [brandDropbox.src, brandHubspot.src, brandLivechat.src, brandPingdom.src, brandScapic.src];
---

<div class="relative">
    <div class="absolute inset-0 -z-10 pointer-events-none pattern-diagonal opacity-30"></div>
    <div
        class="absolute inset-0 -z-10 pointer-events-none bg-linear-to-tr from-transparent via-transparent to-primary/8"
    >
    </div>
    <div class="container">
        <div class="grid grid-cols-3 gap-4 py-10 border-y border-border text-center">
            <div>
                <p class="text-h3 font-bold font-secondary text-text-dark">500+</p>
                <p class="text-sm text-text mt-1">Businesses</p>
            </div>
            <div>
                <p class="text-h3 font-bold font-secondary text-text-dark">৳10 Crore+</p>
                <p class="text-sm text-text mt-1">Transactions Managed</p>
            </div>
            <div>
                <p class="text-h3 font-bold font-secondary text-text-dark">8 hrs/week</p>
                <p class="text-sm text-text mt-1">Average Time Saved</p>
            </div>
        </div>
    </div>
    <section class="section-sm pt-16 xl:pt-20">
        <div class="container">
            <div class="text-center mb-10">
                <p class="text-text-light text-base">
                    Trusted by <strong class="text-primary">500+</strong> businesses across Bangladesh to manage their finances.
                </p>
            </div>
            <div
                class="flex gap-10 xl:gap-x-16 flex-wrap justify-center items-center [&>img]:lg:h-8"
                data-trusted-brands-images={JSON.stringify(brandUrls)}
            >
            </div>
        </div>
    </section>
</div>

<style>
    .pattern-diagonal {
        background-image: url("data:image/svg+xml,%3Csvg width='28' height='28' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 28L28 0M-7 7L7 -7M21 35L35 21' stroke='%23c7d2e0' stroke-width='1'/%3E%3C/svg%3E");
        background-size: 28px 28px;
    }
</style>

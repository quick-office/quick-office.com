---
import { brandDropbox, brandHubspot, brandLivechat, brandPingdom, brandScapic } from '@/lib/assets';
import { Section } from '@/components/ui/section';
import { Container } from '@/components/ui/container';

const brandUrls = [brandDropbox, brandHubspot, brandLivechat, brandPingdom, brandScapic];
---

<div class="relative">
    <div class="absolute inset-0 -z-20 pointer-events-none bg-body"></div>
    <div
        class="absolute inset-0 -z-10 pointer-events-none opacity-30"
        style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='28' height='28' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 28L28 0M-7 7L7 -7M21 35L35 21' stroke='%23c7d2e0' stroke-width='1'/%3E%3C/svg%3E&quot;); background-size: 28px 28px;"
    >
    </div>
    <div
        class="absolute inset-0 -z-10 pointer-events-none bg-linear-to-tr from-transparent via-transparent to-primary/8"
    >
    </div>
    <Container>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 py-10 border-y border-border text-center">
            <div>
                <p class="text-h3 font-bold font-secondary text-text-dark">500+</p>
                <p class="text-sm text-text mt-1">Active Businesses</p>
            </div>
            <div>
                <p class="text-h3 font-bold font-secondary text-text-dark">৳10 Crore+</p>
                <p class="text-sm text-text mt-1">Revenue Tracked</p>
            </div>
            <div>
                <p class="text-h3 font-bold font-secondary text-text-dark">8 hrs/week</p>
                <p class="text-sm text-text mt-1">Saved per Business</p>
            </div>
            <div>
                <p class="text-h3 font-bold font-secondary text-text-dark">98%</p>
                <p class="text-sm text-text mt-1">Customer Satisfaction</p>
            </div>
        </div>
    </Container>
    <Section variant="sm" class="pt-16 xl:pt-20">
        <Container>
            <div class="text-center mb-10">
                <p class="text-text-light text-base">
                    Trusted by <strong class="text-primary">500+ businesses</strong> across Bangladesh — from startups to
                    established SMEs — to streamline invoicing, expenses, and payroll.
                </p>
            </div>
            <div
                class="flex gap-10 xl:gap-x-16 flex-wrap justify-center items-center [&>img]:lg:h-8"
                data-trusted-brands-images={JSON.stringify(brandUrls)}
            >
            </div>
        </Container>
    </Section>
</div>

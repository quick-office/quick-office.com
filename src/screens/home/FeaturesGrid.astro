---
import FeatureCard from '@/layouts/components/FeatureCard.astro';
import VideoShowcase from '@/layouts/components/VideoShowcase.astro';
import { featuresMenuIcon } from '@/lib/assets';

const items = [
    { logo: featuresMenuIcon, title: 'Invoice Creation & Management', is_starred: false },
    { logo: featuresMenuIcon, title: 'Payment Receive & History', is_starred: false },
    { logo: featuresMenuIcon, title: 'Supplier Invoice Management', is_starred: false },
    { logo: featuresMenuIcon, title: 'Supplier Payment Processing', is_starred: false },
    { logo: featuresMenuIcon, title: 'Chart of Accounts', is_starred: true },
    { logo: featuresMenuIcon, title: 'Voucher Creation (Debit/Credit)', is_starred: false },
    { logo: featuresMenuIcon, title: 'Profit & Loss Reports', is_starred: false },
    { logo: featuresMenuIcon, title: 'Cost Center & Cost Analysis', is_starred: false },
    { logo: featuresMenuIcon, title: 'Team Roles & Permissions', is_starred: false },
];
---

<section class="section-box mx-5 relative isolate overflow-hidden">
    <div class="absolute inset-0 -z-10 pointer-events-none pattern-dots opacity-40"></div>
    <div
        class="absolute inset-0 -z-10 pointer-events-none bg-gradient-to-t from-primary/10 via-transparent to-transparent"
    >
    </div>
    <div class="container">
        <div class="section-container">
            <div class="section-intro centralize">
                <h2 class="title hasHighlight">Everything You Need to Run Your <strong>Business Finances</strong></h2>
                <p class="subtitle">From your first invoice to a complete P&L report — Quick Office covers it all.</p>
            </div>
            <div class="section-content">
                <div class="grid sm:grid-cols-2 lg:grid-cols-3 border-r border-text-light/5 border-b">
                    {
                        items.map((item) => (
                            <FeatureCard logo={item.logo} title={item.title} is_starred={item.is_starred} />
                        ))
                    }
                </div>
                <div class="mt-16 flex justify-center w-full perspective-near xl:perspective-dramatic">
                    <VideoShowcase />
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .pattern-dots {
        background-image: url("data:image/svg+xml,%3Csvg width='36' height='36' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='18' cy='18' r='1.5' fill='%23b8c6d6'/%3E%3C/svg%3E");
        background-size: 36px 36px;
    }
</style>

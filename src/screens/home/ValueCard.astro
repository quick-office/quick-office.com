---
import type { ImageMetadata } from 'astro';
import ImageMod from '@/components/ImageMod.astro';
interface Props {
    logo: ImageMetadata | string;
    title: string;
    list?: string[];
}
const { logo, title, list } = Astro.props;
---

<div class="p-8 rounded-2xl bg-black/5">
    <ImageMod src={logo} alt={`${title} icon`} class="mb-6" />
    <h3 class="text-h5-sm font-bold">{title}</h3>
    <ul class="stars-list mt-5 text-text-dark">
        {list?.map((item) => <li>{item}</li>)}
    </ul>
</div>

<style>
    ul.stars-list {
        @apply list-none pl-0;
        li {
            @apply relative mb-3 pl-6;

            &::before {
                content: '';
                @apply absolute left-0 mt-0.5 size-4 translate-y-[4px];
                background-image: url('data:image/svg+xml;base64,');
                background-position: center;
                background-repeat: no-repeat;
                background-size: 16px 16px;
            }
        }
    }
</style>

---
import { Section } from '@/components/ui/section';

const items = [
    'Invoices Lost in Email Threads',
    'No Real-Time Cash Visibility',
    'Manual Voucher Creation',
    'Chasing Supplier Payments',
    'Month-End Accounting Panic',
    'Multiple Disconnected Tools',
];
---

<Section class="pt-30 xl:pt-37 relative">
    <div class="absolute inset-0 -z-20 pointer-events-none bg-body"></div>
    <div class="absolute inset-0 -z-10 pointer-events-none pattern-plus opacity-30"></div>
    <div class="absolute inset-0 -z-10 pointer-events-none bg-gradient-to-bl from-primary/10 to-transparent"></div>
    <div class="absolute inset-0 -z-10 pointer-events-none bg-gradient-to-tr from-primary/8 to-transparent"></div>
    <div class="container">
        <div class="flex flex-col gap-10 lg:gap-16">
            <div class="flex flex-col items-center gap-y-5 text-center">
                <h2 class="mx-auto mb-2 text-h3 lg:col-10 lg:text-h2 [&_strong]:text-primary">
                    Still managing finances with <strong>spreadsheets and guesswork?</strong>
                </h2>
                <p class="mx-auto text-lg text-text lg:col-7">
                    Manual accounting is slow and error-prone. Quick Office gives you a complete financial system that
                    works the way your business actually does.
                </p>
            </div>
            <div class="mb-0">
                <div class="feature-items-group mb-9">
                    {
                        items.slice(0, 3).map((text) => (
                            <div class="bg-body border border-border px-4 w-full py-2.5 rounded-full flex items-center justify-center relative z-10 gap-x-2">
                                <svg class="shrink-0" width="20" height="20" viewBox="0 0 20 20" fill="none">
                                    <path
                                        d="M9.99999 1.04163C14.9476 1.04163 18.9583 5.05241 18.9583 9.99996C18.9583 14.9475 14.9476 18.9583 9.99999 18.9583C5.05244 18.9583 1.04166 14.9475 1.04166 9.99996C1.04166 5.05241 5.05244 1.04163 9.99999 1.04163ZM8.02571 6.8538C7.69841 6.58685 7.2159 6.6057 6.9108 6.91077C6.60581 7.21587 6.5869 7.6984 6.85383 8.02568L6.9108 8.08915L8.82157 9.99996L6.91161 11.9108C6.5863 12.2362 6.58619 12.7638 6.91161 13.0891C7.23705 13.4143 7.76464 13.4145 8.09 13.0891L9.99999 11.1784L11.91 13.0891L11.9735 13.1461C12.3007 13.413 12.7832 13.394 13.0884 13.0891C13.3934 12.7842 13.4128 12.3015 13.1462 11.9742L13.0884 11.9108L11.1776 9.99996L13.0892 8.08915L13.1462 8.02568C13.4131 7.69839 13.3942 7.21587 13.0892 6.91077C12.7841 6.6057 12.3016 6.58685 11.9742 6.8538L11.9108 6.91077L9.99999 8.82154L8.08918 6.91077L8.02571 6.8538Z"
                                        fill="var(--color-secondary)"
                                    />
                                </svg>
                                <span class="font-semibold text-text-dark text-lg">{text}</span>
                            </div>
                        ))
                    }
                </div>
                <div class="feature-items-group">
                    {
                        items.slice(3).map((text) => (
                            <div class="bg-body border border-border px-4 w-full py-2.5 rounded-full flex items-center justify-center relative z-10 gap-x-2">
                                <svg class="shrink-0" width="20" height="20" viewBox="0 0 20 20" fill="none">
                                    <path
                                        d="M9.99999 1.04163C14.9476 1.04163 18.9583 5.05241 18.9583 9.99996C18.9583 14.9475 14.9476 18.9583 9.99999 18.9583C5.05244 18.9583 1.04166 14.9475 1.04166 9.99996C1.04166 5.05241 5.05244 1.04163 9.99999 1.04163ZM8.02571 6.8538C7.69841 6.58685 7.2159 6.6057 6.9108 6.91077C6.60581 7.21587 6.5869 7.6984 6.85383 8.02568L6.9108 8.08915L8.82157 9.99996L6.91161 11.9108C6.5863 12.2362 6.58619 12.7638 6.91161 13.0891C7.23705 13.4143 7.76464 13.4145 8.09 13.0891L9.99999 11.1784L11.91 13.0891L11.9735 13.1461C12.3007 13.413 12.7832 13.394 13.0884 13.0891C13.3934 12.7842 13.4128 12.3015 13.1462 11.9742L13.0884 11.9108L11.1776 9.99996L13.0892 8.08915L13.1462 8.02568C13.4131 7.69839 13.3942 7.21587 13.0892 6.91077C12.7841 6.6057 12.3016 6.58685 11.9742 6.8538L11.9108 6.91077L9.99999 8.82154L8.08918 6.91077L8.02571 6.8538Z"
                                        fill="var(--color-secondary)"
                                    />
                                </svg>
                                <span class="font-semibold text-text-dark text-lg">{text}</span>
                            </div>
                        ))
                    }
                </div>
            </div>
            </div>
        </div>
    </div>
</Section>

<style>
    .feature-items-group {
        @apply relative isolate flex flex-wrap items-center justify-between gap-x-18 gap-y-8 xl:flex-nowrap;
    }
    .feature-items-group::before {
        content: '';
        @apply absolute top-1/2 left-0 z-0 h-[1px] w-full bg-black/20;
    }
    .feature-items-group::after {
        content: '';
        @apply absolute top-1/2 left-0 z-0 h-[1px] w-full bg-border/70;
    }
    .feature-items-group > * {
        @apply relative z-10 bg-white;
    }
    .pattern-plus {
        background-image: url("data:image/svg+xml,%3Csvg width='32' height='32' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M16 6v20M6 16h20' stroke='%23c7d2e0' stroke-width='1' stroke-linecap='round'/%3E%3C/svg%3E");
        background-size: 32px 32px;
    }
</style>

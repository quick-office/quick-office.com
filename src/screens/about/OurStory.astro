---
import ImageMod from '@/components/ImageMod.astro';
import { avatarLg } from '@/lib/assets';

const ourStory = {
    enable: true,
    title: 'Why We Built Quick Office — A Note From <strong>Our Founder</strong>',
    ceo: {
        image: avatarLg,
        name: 'Rahim Chowdhury',
        role: 'Co-Founder & CEO',
    },
    letter: `<p><strong class="text-white font-normal">In 2021, I was helping manage my family's trading business in Dhaka — and I was drowning in spreadsheets, WhatsApp follow-ups, and three separate apps just to track invoices and stay on top of leads.</strong> Every missed call was a missed sale. Every manual follow-up we forgot to send was a customer lost to a competitor. I knew we weren't the only ones dealing with this.</p><br><p>Every business owner I spoke to had the same problem: too many disconnected tools, too much admin work, and no clear system for turning new contacts into paying customers. So we built Quick Office — not a generic Western SaaS product with a language toggle, but a platform built from the ground up for how local businesses in Bangladesh actually operate: invoicing in BDT, payments via bKash and Nagad, and automation workflows that run 24/7 so you don't have to.</p>`,
    letter_points_title: 'Our commitment to every customer:',
    letter_points: [
        'Local support team, available 6 days a week',
        'Transparent pricing — no hidden fees, ever',
        'Your data stays secure, always backed up',
    ],
    closing_content:
        "We're building the platform we wish we had — and every new feature comes directly from feedback from business owners just like you. Thank you for being part of this journey.",
    button: { enable: true, label: 'Start Your 30-Day Free Trial', link: '/pricing' },
};

if (!ourStory.enable) return;
---

<section class="section overflow-hidden">
    <div class="container">
        <div class="section-container">
            <div class="section-intro centralize">
                <h2 class="title hasHighlight lg:col-8 mx-auto" set:html={ourStory.title} />
            </div>
            <div class="section-content">
                <hr class="border-border" />
                <div class="relative max-w-220 mx-auto">
                    <div class="p-6 py-20 xl:px-15 border-x border-text/10">
                        <div class="flex flex-col items-center text-center lg:max-w-3xl mx-auto">
                            <div>
                                <ImageMod
                                    width={211}
                                    height={211}
                                    class="size-52 rounded-full mb-7"
                                    src={ourStory.ceo.image}
                                    alt={ourStory.ceo.name}
                                />
                                <p class="text-text-dark font-semibold">{ourStory.ceo.name}</p>
                                <p class="text-text-dark text-sm">{ourStory.ceo.role}</p>
                            </div>
                            <div class="text-h6 mt-12 mb-17 text-left mx-auto">
                                <div set:html={ourStory.letter} />
                            </div>
                            {
                                ourStory.letter_points.length > 0 && (
                                    <>
                                        <div class="text-h6 text-text-dark font-semibold text-center mb-7">
                                            {ourStory.letter_points_title}
                                        </div>
                                        <div class="flex flex-col gap-y-7 relative vertical-bg-line">
                                            {ourStory.letter_points.map((point) => (
                                                <div class="bg-light border border-border px-8 w-full py-2.5 rounded-full flex items-center justify-center relative z-10 gap-x-2">
                                                    <span class="font-semibold text-text-dark text-lg">{point}</span>
                                                </div>
                                            ))}
                                        </div>
                                    </>
                                )
                            }
                            {ourStory.closing_content && <p class="mt-15 text-h6">{ourStory.closing_content}</p>}
                            {
                                ourStory.button.enable && ourStory.button.link && (
                                    <div class="mt-12 flex justify-center">
                                        <a href={ourStory.button.link} class="btn btn-primary py-4">
                                            {ourStory.button.label}
                                        </a>
                                    </div>
                                )
                            }
                        </div>
                    </div>
                    <div class="size-2 bg-white absolute left-0 top-0 -translate-x-1/2 -translate-y-1/2" />
                    <div class="size-2 bg-white absolute right-0 top-0 translate-x-1/2 -translate-y-1/2" />
                    <div class="size-2 bg-white absolute left-0 bottom-0 -translate-x-1/2 translate-y-1/2" />
                    <div class="size-2 bg-white absolute right-0 bottom-0 translate-x-1/2 translate-y-1/2" />
                </div>
                <hr class="border-border" />
            </div>
        </div>
    </div>
</section>

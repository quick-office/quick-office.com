---
import GradientBlob from '@/components/GradientBlob.astro';
import TestimonialCard from '@/components/TestimonialCard.astro';
import { testimonial1, testimonial2, testimonial3, bannerShowcaseVideo } from '@/lib/assets';

const testimonial = {
    enable: true,
    title: 'Real Stories From <strong>Business Owners Like You</strong>',
    testimonials: [
        {
            name: 'Karim Rahman',
            designation: 'Owner, Rahman Trading Co. — Dhaka',
            poster: testimonial1,
            video: bannerShowcaseVideo,
            content:
                "Before Quick Office, I was losing at least 5 leads a week just because we couldn't follow up fast enough. Now the system does it automatically. Our bookings went up 40% in the first two months.",
        },
        {
            name: 'Nadia Islam',
            designation: 'Operations Manager — Chittagong',
            poster: testimonial2,
            video: bannerShowcaseVideo,
            content:
                'We replaced four tools with one. Invoicing, expense tracking, customer follow-ups, and review requests — all from a single dashboard. It saves us 15+ hours every week.',
        },
        {
            name: 'Arif Hossain',
            designation: 'Finance Director — Dhaka',
            poster: testimonial3,
            video: bannerShowcaseVideo,
            content:
                'Setup took less than an hour and we sent our first automated follow-up the same day. The bKash and Nagad payment integration alone was worth it — our clients actually pay on time now.',
        },
    ],
};
---

{
    testimonial.enable && (
        <section class="section relative">
            <div class="container">
                <div class="section-container">
                    <div class="section-intro centralize">
                        <h2 class="title hasHighlight" set:html={testimonial.title} />
                    </div>
                    <div class="section-content">
                        <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-7">
                            {testimonial.testimonials.map((item) => (
                                <TestimonialCard
                                    poster={item.poster}
                                    name={item.name}
                                    designation={item.designation}
                                    content={item.content}
                                    video={item.video}
                                />
                            ))}
                        </div>
                    </div>
                </div>
            </div>
            <GradientBlob />
        </section>
    )
}

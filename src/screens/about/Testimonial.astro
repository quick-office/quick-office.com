---
import GradientBlob from '@/components/GradientBlob.astro';
import TestimonialCard from '@/components/TestimonialCard.astro';

const testimonial = {
    enable: true,
    title: 'Real Stories From <strong>Business Owners Like You</strong>',
    testimonials: [
        {
            name: 'Karim Rahman',
            designation: 'Owner, Rahman Trading Co. — Dhaka',
            poster: '/images/testimonials/1.png',
            content: 'Before Quick Office, I was losing at least 5 leads a week just because we couldn\'t follow up fast enough. Now the system does it automatically. Our bookings went up 40% in the first two months.',
            video: '/showcase.mp4',
        },
        {
            name: 'Nadia Islam',
            designation: 'Operations Manager — Chittagong',
            poster: '/images/testimonials/2.png',
            content: 'We replaced four tools with one. Invoicing, expense tracking, customer follow-ups, and review requests — all from a single dashboard. It saves us 15+ hours every week.',
            video: '/showcase.mp4',
        },
        {
            name: 'Arif Hossain',
            designation: 'Finance Director — Dhaka',
            poster: '/images/testimonials/3.png',
            content: 'Setup took less than an hour and we sent our first automated follow-up the same day. The bKash and Nagad payment integration alone was worth it — our clients actually pay on time now.',
            video: '/showcase.mp4',
        },
    ],
};
---

{
    testimonial.enable && (
        <section class="section relative">
            <div class="container">
                <div class="section-container">
                    <div class="section-intro centralize">
                        <h2 class="title hasHighlight" set:html={testimonial.title} />
                    </div>
                    <div class="section-content">
                        <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-7">
                            {testimonial.testimonials.map((item) => (
                                <TestimonialCard
                                    poster={item.poster}
                                    name={item.name}
                                    designation={item.designation}
                                    content={item.content}
                                    video={item.video}
                                />
                            ))}
                        </div>
                    </div>
                </div>
            </div>
            <GradientBlob />
        </section>
    )
}

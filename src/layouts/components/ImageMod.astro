---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
    src: ImageMetadata | string;
    alt: string;
    width?: number;
    height?: number;
    loading?: 'eager' | 'lazy' | null | undefined;
    decoding?: 'async' | 'auto' | 'sync' | null | undefined;
    format?: 'auto' | 'avif' | 'jpeg' | 'png' | 'svg' | 'webp';
    fit?: 'cover' | 'contain' | 'fill' | 'none' | 'scale-down';
    class?: string;
    style?: any;
}

const assets = import.meta.glob<{ default: ImageMetadata }>(
    ['/src/assets/images/**/*.{svg,png,jpg,jpeg,webp,gif}', '/src/assets/vectors/**/*.svg'],
    { eager: true },
);

function resolveAsset(path: string): ImageMetadata | string {
    const fromImages = path.replace(/^\/images\//, '/src/assets/images/');
    const fromVectors = path.replace(/^\/images\//, '/src/assets/vectors/');
    return assets[fromImages]?.default ?? assets[fromVectors]?.default ?? path;
}

const { src, alt, width, height, loading, decoding, class: className, format, style, fit } = Astro.props;

const resolved = typeof src === 'string' ? resolveAsset(src) : src;
const isMetadata = typeof resolved === 'object' && resolved !== null;
---

{
    isMetadata ? (
        <Image
            src={resolved as ImageMetadata}
            alt={alt}
            width={width as any}
            height={height as any}
            loading={loading}
            fit={fit ?? 'contain'}
            decoding={decoding}
            class={className}
            format={format}
            style={style}
        />
    ) : resolved ? (
        <img
            src={resolved as string}
            alt={alt}
            width={width}
            height={height}
            loading={loading ?? 'lazy'}
            decoding={decoding ?? 'async'}
            class={className}
            style={style}
        />
    ) : null
}

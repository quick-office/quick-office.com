---
import '@/styles/main.css';

import { siteName } from '@/lib/config';
import { ogImage as ogImageAsset } from '@/lib/assets';

import Footer from './Footer.astro';
import Header from './Header.astro';

export interface Props {
    title: string;
    description: string;
    image?: string;
    noindex?: boolean;
    canonical?: string;
}

const { title, description, image, noindex, canonical } = Astro.props;

const stickyHeader = true;

const pageTitle = `${title} - ${siteName}`;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <!-- Favicons & PWA manifest -->
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
        <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
        <link rel="manifest" href="/site.webmanifest" />
        <meta name="theme-color" content="#6d56e8" />

        <!-- Fonts: Inter Tight (body) + Urbanist (headings) — preconnect + preloaded stylesheet -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="preload"
            as="style"
            href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600&family=Urbanist:wght@500;700&display=swap"
        />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600&family=Urbanist:wght@500;700&display=swap"
        />

        <!-- Viewport & title -->
        <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
        <title>
            {pageTitle}
        </title>

        <!-- SEO -->
        {canonical && <link rel="canonical" href={canonical} item-prop="url" />}
        {noindex && <meta name="robots" content="noindex,nofollow" />}
        <meta name="description" content={description} />
        <meta name="author" content={siteName} />

        <!-- Open Graph -->
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
        <meta property="og:image" content={new URL(image || ogImageAsset.src, Astro.site).href} />

        <!-- Twitter card -->
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={new URL(image || ogImageAsset.src, Astro.site).href} />
        <meta name="twitter:card" content="summary_large_image" />

        <!-- GSAP CDN -->
        <script is:inline defer src="https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/gsap.min.js"></script>
        <script is:inline defer src="https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/ScrollTrigger.min.js"></script>

        <!-- Main UI interactions & animations (bundled by Vite) -->
        <script>
            import '@/scripts/main.js';
        </script>
        <script>
            import '@/scripts/animations.js';
        </script>
    </head>
    <body>
        {/* <TwSizeIndicator /> */}
        <Header stickyHeader={stickyHeader} />
        <main id="main-content" class="overflow-x-hidden md:overflow-x-auto">
            <slot />
        </main>
        <Footer />
    </body>
</html>

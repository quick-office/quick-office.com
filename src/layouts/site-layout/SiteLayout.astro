---
import config from '@/config/config.json';
import { plainify } from '@/lib/utils/textConverter';
import Footer from '@/layouts/partials/Footer.astro';
import Header from '@/layouts/partials/Header.astro';
import '@/styles/main.css';

export interface Props {
    title: string;
    description?: string;
    image?: string;
    noindex?: boolean;
    canonical?: string;
}

const { title, description, image, noindex, canonical } = Astro.props;

const siteName = 'Quick Office';

const pageTitle = `${title} - ${siteName}`;
---

<!doctype html>
<html lang="en">
    <head>
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
        <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
        <link rel="manifest" href="/site.webmanifest" />

        <meta name="theme-name" content="quick-office" />
        <meta name="msapplication-TileColor" content="#000000" />
        <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fff" />
        <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#000" />
        <meta name="generator" content={Astro.generator} />
        <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

        <!-- Fonts: Inter Tight (body) + Urbanist (headings) — preconnect + preloaded stylesheet -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="preload"
            as="style"
            href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600&family=Urbanist:wght@500;700&display=swap"
        />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600&family=Urbanist:wght@500;700&display=swap"
        />

        <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />

        <title>
            {pageTitle}
        </title>

        {canonical && <link rel="canonical" href={canonical} item-prop="url" />}
        {noindex && <meta name="robots" content="noindex,nofollow" />}
        <meta name="description" content={plainify(description ? description : config.metadata.meta_description)} />

        <!-- View Transitions removed to avoid conflicts with GSAP/Swiper -->

        <meta name="author" content={config.metadata.meta_author} />
        <meta property="og:title" content={pageTitle} />
        <meta
            property="og:description"
            content={plainify(description ? description : config.metadata.meta_description)}
        />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={`${config.site.base_url}/${Astro.url.pathname.replace('/', '')}`} />
        <meta name="twitter:title" content={pageTitle} />
        <meta
            name="twitter:description"
            content={plainify(description ? description : config.metadata.meta_description)}
        />
        <meta property="og:image" content={`${config.site.base_url}${image ? image : config.metadata.meta_image}`} />
        <meta name="twitter:image" content={`${config.site.base_url}${image ? image : config.metadata.meta_image}`} />
        <meta name="twitter:card" content="summary_large_image" />

        <!-- GSAP CDN -->
        <script is:inline defer src="https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/gsap.min.js"></script>
        <script is:inline defer src="https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/ScrollTrigger.min.js"></script>

        <!-- Main UI interactions -->
        <script is:inline defer src="/scripts/main.js"></script>

        <!-- Animations (Modules are deferred automatically by browsers) -->
        <script is:inline type="module" src="/scripts/animations.js"></script>
    </head>
    <body>
        {/* <TwSizeIndicator /> */}
        <Header />
        <main id="main-content" class="overflow-x-hidden md:overflow-x-auto">
            <slot />
        </main>
        <Footer />
    </body>
</html>
